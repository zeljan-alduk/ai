{
  "name": "@aldo-ai/mcp-git",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "ALDO AI first-party MCP server: typed git + gh surface with policy gates (protected branches, force-push, remote allowlist).",
  "license": "FSL-1.1-ALv2",
  "main": "./src/index.ts",
  "bin": {
    "aldo-mcp-git": "./dist/index.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node --import=tsx/esm src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
