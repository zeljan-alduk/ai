{
  "name": "@meridian/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Meridian command-line tool (meridian).",
  "bin": {
    "meridian": "./dist/index.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc",
    "build:bin": "bun build ./src/index.ts --compile --target=bun --outfile dist/meridian"
  },
  "dependencies": {
    "@meridian/types": "workspace:*",
    "@meridian/registry": "workspace:*",
    "commander": "^12.1.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
