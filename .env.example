# ALDO AI — environment template
# Copy to `.env` and fill in. The CLI auto-loads `.env` from the
# repository root and from `~/.config/aldo/env` (if present).
# Never commit a real `.env`.

# ---- Provider keys (BYO). Leave a key blank to disable that provider. ----

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# OpenAI / GPT (https://platform.openai.com/)
OPENAI_API_KEY=

# Google Gemini (https://aistudio.google.com/)
GEMINI_API_KEY=

# Groq — generous free tier, fast Llama / Qwen / Mixtral hosting
# (https://console.groq.com/)
GROQ_API_KEY=

# OpenRouter (https://openrouter.ai/)
OPENROUTER_API_KEY=

# xAI Grok (https://console.x.ai/)
XAI_API_KEY=

# AWS Bedrock — provide standard AWS credentials via your environment
# or AWS profile. Bedrock adapter is a stub in v0.

# ---- Local backends ----

# Ollama daemon — default localhost:11434, no key.
OLLAMA_BASE_URL=http://localhost:11434

# vLLM / llama.cpp / LM Studio / TGI — set if running anywhere non-default.
VLLM_BASE_URL=
LLAMACPP_BASE_URL=
LM_STUDIO_BASE_URL=
TGI_BASE_URL=

# ---- Storage ----

# Postgres (Neon recommended for free-tier dev). Required once the
# Postgres-backed registry / checkpointer / span exporter ship.
DATABASE_URL=

# Object storage for replay bundles (S3-compatible; Cloudflare R2 in practice).
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=aldo-artifacts-dev

# ---- Observability ----

# OTEL collector / backend (Langfuse self-host, Phoenix, or any OTLP endpoint).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ---- Defaults ----

# Default privacy tier for ad-hoc runs when an agent spec doesn't pin one.
ALDO_DEFAULT_PRIVACY=internal

# Hard kill-switch: cap any single run at this many USD across all providers.
ALDO_RUN_USD_CAP=1.00

# ---- Stripe billing (optional — placeholder mode when unset) ----
#
# All five vars must be set together for the API to leave placeholder
# mode and start minting Checkout / Portal sessions. With any of them
# blank, /v1/billing/checkout, /v1/billing/portal, /v1/billing/webhook
# return the typed `not_configured` envelope (HTTP 503) and the
# /pricing page disables the Solo + Team CTAs with "Billing setup
# pending". The 14-day trial keeps working — only the credit-card
# step is gated.
#
# Use Stripe TEST keys (sk_test_… / whsec_…) by default. Live keys
# (sk_live_…) should only land in production secrets via the deploy
# workflow — never commit either to the repo.

# Stripe secret key — server-side API. Starts with `sk_test_…` or `sk_live_…`.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret. Starts with `whsec_…`. Stripe shows
# this when you create a webhook endpoint in the dashboard or via
# `stripe listen --forward-to localhost:3001/v1/billing/webhook`.
STRIPE_WEBHOOK_SIGNING_SECRET=

# Stripe price IDs for the priced plans. Create these once in the
# Stripe Dashboard (Products → Add product → recurring monthly).
# Format: `price_…`. Solo = $29/mo, Team = $99/mo per the /pricing page.
STRIPE_PRICE_SOLO=
STRIPE_PRICE_TEAM=

# Optional alias kept for forward-compat with the Enterprise tier. The
# pricing page still routes Enterprise to a `mailto:` so this is
# unused at MVP — set it once self-serve Enterprise checkout lands.
STRIPE_PRICE_ENTERPRISE=

# Where Stripe redirects the customer after they close the Billing
# Portal. Absolute URL — e.g. https://ai.aldo.tech/billing
STRIPE_BILLING_PORTAL_RETURN_URL=

# Stripe publishable key (web bundle). Currently unused — Stripe
# Checkout is server-redirect, not Stripe.js. Reserved for the
# Elements / Payment Element migration if/when we move away from
# hosted checkout.
STRIPE_PUBLISHABLE_KEY=
